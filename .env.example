# Copy this file to .env and fill in your values
# NOTION_API_KEY — from https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_your_notion_integration_token

# GRANOLA_API_KEY — from your Granola account settings
GRANOLA_API_KEY=your_granola_api_token

# Optional: override the parent page ID from config.yaml
# NOTION_PARENT_PAGE_ID=336916a5-3018-8016-98d0-c105d579134f
